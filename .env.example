# ─────────────────────────────────────────────────────────
# BioFit 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env로 복사:    cp .env.example .env
#   2. 모든 replace_* 값을 실제 값으로 교체
#   3. .env는 .gitignore에 등록되어 있어 git에 올라가지 않음
#
# 운영 환경에서는 *반드시* 강력한 비밀번호로 교체하세요.
# ─────────────────────────────────────────────────────────

# PostgreSQL 컨테이너
POSTGRES_USER=biofit
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=biofitdb

# 서비스 간 DB 연결 (컨테이너 내부)
# 위의 POSTGRES_USER/POSTGRES_PASSWORD와 일치하도록 작성
DATABASE_URL=postgresql://biofit:replace_with_strong_password@db:5432/biofitdb

# Streamlit이 직접 DB 접속 시 사용 (Phase 5 옵트아웃 fallback path)
DB_HOST=db
DB_PORT=5432
DB_NAME=biofitdb
DB_USER=biofit
DB_PASSWORD=replace_with_strong_password

# vLLM (OpenAI-compatible) — 외부 GPU 서버
OPENAI_BASE=http://YOUR_VLLM_HOST:8004/v1
OPENAI_KEY=replace_with_your_token
LLM_MODEL_NAME=openai/gpt-oss-20b
